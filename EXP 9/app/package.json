{
  "name": "exp-3-2-3-app",
  "version": "1.0.0",
  "description": "Full-stack application for AWS deployment experiment",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "docker:build": "docker build -t exp-3-2-3-app:latest .",
    "docker:run": "docker run -p 3000:3000 exp-3-2-3-app:latest"
  },
  "keywords": [
    "aws",
    "deployment",
    "load-balancing",
    "docker",
    "autoscaling"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "pg": "^8.10.0",
    "redis": "^4.6.5",
    "morgan": "^1.10.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.0",
    "pino": "^8.14.1",
    "pino-pretty": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "typescript": "^5.1.3",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "eslint": "^8.43.0",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
